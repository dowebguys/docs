{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "NIL Benchmark",
  "colors": {
    "primary": "#0f1f38",
    "light": "#e8a020",
    "dark": "#0f1f38"
  },
  "favicon": "/favicon.svg",
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      { "label": "Support", "href": "mailto:support@nilbenchmark.com" }
    ],
    "primary": {
      "type": "button",
      "label": "Launch App",
      "href": "http://localhost:3000"
    }
  },
  "footer": {
    "socials": {
      "github": "https://github.com/dowebguys"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Overview",
        "groups": [
          {
            "group": "Getting Started",
            "pages": ["index", "quickstart", "architecture"]
          },
          {
            "group": "Platform Pages",
            "pages": [
              "pages/dashboard",
              "pages/athletes",
              "pages/agreements",
              "pages/upload-wizard",
              "pages/benchmarks",
              "pages/budget",
              "pages/reporting",
              "pages/settings",
              "pages/auth"
            ]
          }
        ]
      },
      {
        "tab": "Database & API",
        "groups": [
          {
            "group": "Database",
            "pages": ["database/schema", "database/seed-data"]
          },
          {
            "group": "API Reference",
            "pages": [
              "api/auth",
              "api/athletes",
              "api/deals",
              "api/upload",
              "api/benchmarks",
              "api/budget",
              "api/reporting",
              "api/admin"
            ]
          }
        ]
      },
      {
        "tab": "Engineering",
        "groups": [
          {
            "group": "Development",
            "pages": ["engineering/local-setup", "engineering/docker", "engineering/frontend", "engineering/backend"]
          },
          {
            "group": "Features",
            "pages": ["engineering/rbac", "engineering/email", "engineering/extraction", "engineering/benchmarking"]
          },
          {
            "group": "Handoff",
            "pages": ["engineering/next-steps"]
          }
        ]
      }
    ]
  }
}
